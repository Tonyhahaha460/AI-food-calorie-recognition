FLASK_ENV=development
PORT=5000
MAX_CONTENT_LENGTH=4194304
ALLOWED_EXTENSIONS=jpg,jpeg,png
CORS_ORIGINS=http://localhost:5173
DATABASE_PATH=local_assets/backend/database/app.db
HISTORY_STORAGE_PATH=local_assets/backend/history/analysis_history.json
HISTORY_MAX_RECORDS=50
JOURNAL_STORAGE_PATH=local_assets/backend/journal/journal_entries.json
AUTH_STORAGE_PATH=local_assets/backend/auth/members.json
AUTH_SECRET_KEY=change-me-in-production
AUTH_TOKEN_MAX_AGE=604800
MODEL_PROVIDER=yolo_cls
ALL_FOOD_CLASSIFIER_MODEL_PATH=runs/all_food_cls/uec_food101_yolov8n_cls-3/weights/best.pt
FOOD_DATASET_ROOT=local_assets/backend/dataset
HF_HOME=../local_assets/backend/.cache/huggingface
YOLO_CONFIG_DIR=../local_assets/backend/.cache/Ultralytics
CHINESE_FOOD_MODEL_NAME=Albertbeta123/resnet-50-chinese-food
HF_IMAGE_CLASSIFIER_MODEL=nateraw/food
CHINESE_TOP_K=3
HF_CLASSIFIER_TOP_K=5
YOLO_HF_DIRECT_ACCEPT_THRESHOLD=0.90
CHINESE_CONFIDENCE_THRESHOLD=0.80
GENERAL_CONFIDENCE_THRESHOLD=0.65
MIN_ACCEPTED_CONFIDENCE=0.72
YOLO_CLS_MIN_ACCEPTED_CONFIDENCE=0.20
YOLO_CLS_MIN_CONFIDENCE_MARGIN=0.10
LOCAL_PRIORITY_THRESHOLD=0.78
HYBRID_SCORE_MARGIN=0.08
YOLO_MODEL_NAME=../local_assets/backend/model_artifacts/yolov8n.pt
YOLO_DETECTION_CONFIDENCE=0.25
YOLO_MAX_DETECTIONS=6
AUTO_DETECTION_MIN_CONFIDENCE=0.62
AUTO_SINGLE_ITEM_ACCEPT_CONFIDENCE=0.85
AUTO_MULTI_ITEM_COUNT=2
TRAINED_MODEL_PATH=../local_assets/backend/model_artifacts/meal_classifier.pkl
MOBILENET_REGRESSION_MODEL_PATH=../local_assets/backend/model_artifacts/mobilenet_regressor.pt
MOBILENET_REGRESSION_SUMMARY_PATH=../local_assets/backend/model_artifacts/training_summary.json
NUTRITION5K_ROOT=../local_assets/backend/dataset/nutrition5k
NUTRITION5K_METADATA_PATH=app/data/nutrition5k_metadata.json
FOOD101_ROOT=../local_assets/backend/dataset
FOOD101_USE=false
FOOD101_DOWNLOAD_ON_TRAIN=false
FOOD101_TRAIN_SAMPLES_PER_LABEL=120
FOOD101_VAL_SAMPLES_PER_LABEL=40
CUSTOM_TRAIN_REPEAT=12
